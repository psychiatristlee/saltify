rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper: admin check via custom claim
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Blog media - public read, admin-only write
    match /blog-media/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Menu images for the order/pickup system
    match /menu-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
