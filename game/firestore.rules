rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin via custom claims
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Referrals collection
    match /referrals/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // Coupons collection
    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // Branches collection (authenticated users can read for password validation)
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Game records collection
    match /gameRecords/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.userId);
    }

    // Bread points collection
    match /breadPoints/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Admins collection (fallback admin check by uid)
    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Blog posts - public read (published posts rendered on website), admin write
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Media items metadata - admin-only
    match /mediaItems/{itemId} {
      allow read, write: if isAdmin();
    }

    // Tracked keywords for Naver rank - admin-only
    match /trackedKeywords/{keywordId} {
      allow read, write: if isAdmin();
    }

    // Blog config (daily counts per language) - admin-only
    match /blogConfig/{docId} {
      allow read, write: if isAdmin();
    }

    // ===== Order / Pickup system =====

    // Menu items — public read so any signed-in user can browse,
    // admin-only writes (CRUD via admin UI).
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders — owner or admin reads. Signed-in user can create their own
    // order document. Mutations (status, payment) are admin/Cloud Function only;
    // the customer can cancel their own pending order via Cloud Function.
    match /orders/{orderId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();

      match /payments/{paymentId} {
        allow read: if isAuthenticated()
          && (get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid
              || isAdmin());
        allow write: if isAdmin();
      }

      match /events/{eventId} {
        allow read: if isAuthenticated()
          && (get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid
              || isAdmin());
        allow write: if isAdmin();
      }
    }

    // Daily counter for pickup numbers (managed by Cloud Function).
    match /pickupCounters/{date} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Tycoon mode 영업 일지 — owner-only read/write.
    match /tycoonJournals/{userId} {
      allow read, write: if isOwner(userId);
      match /days/{dayNumber} {
        allow read, write: if isOwner(userId);
      }
    }

  }
}
